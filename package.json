{
  "name": "grove-keeper",
  "private": true,
  "version": "1.0.0-alpha.1",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "install-and-dev": "pnpm install && pnpm dev",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview --port 8080",
    "tsc": "tsc",
    "tscgo": "tsgo",
    "tsc-watch": "tsc --watch",
    "dev:prod": "concurrently \"npm run build:watch\" \"npm run preview\"",
    "test": "vitest --project node",
    "test:run": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project node --coverage",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui",
    "test:playthrough": "playwright test e2e/playthrough.spec.ts",
    "test:rc-journey": "pnpm build && playwright test e2e/rc-journey.spec.ts",
    "test:rc-perf": "pnpm build && playwright test e2e/perf.spec.ts",
    "audit:lighthouse": "pnpm build && lhci autorun --config=lighthouserc.cjs",
    "size": "size-limit",
    "assets:fetch": "node scripts/fetch-itch.mjs",
    "assets:import": "node scripts/import-from-voxel-realms.mjs",
    "assets:sample": "node scripts/sample-animations.mjs",
    "assets:convert": "node scripts/convert-dae-to-glb.mjs",
    "assets:curate": "node scripts/curate-assets.mjs",
    "assets:manifest": "node scripts/build-asset-manifest.mjs",
    "assets:all": "pnpm assets:import && pnpm assets:convert && pnpm assets:curate && pnpm assets:manifest"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@dimforge/rapier3d": "^0.19.3",
    "@jolly-pixel/engine": "^2.5.0",
    "@jolly-pixel/runtime": "^3.3.0",
    "@jolly-pixel/voxel.renderer": "^1.4.0",
    "@tailwindcss/vite": "^4.1.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "nipplejs": "^0.10.2",
    "solid-js": "^1.9.12",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "three": "~0.182.0",
    "yuka": "^0.7.8"
  },
  "pnpm": {
    "overrides": {
      "@playwright/test": "1.59.1",
      "playwright": "1.59.1",
      "esbuild": ">=0.25.0",
      "tar": ">=7.5.11",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "picomatch@>=4.0.0": ">=4.0.4",
      "picomatch@<2.3.2": ">=2.3.2",
      "@xmldom/xmldom": ">=0.8.13"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3",
    "@capacitor/cli": "^8.0.2",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "1.59.1",
    "@size-limit/file": "^12.1.0",
    "@solidjs/testing-library": "^0.8.10",
    "@types/sql.js": "^1.4.9",
    "@types/three": "~0.182.0",
    "@types/yuka": "^0.7.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.8",
    "happy-dom": "^20.9.0",
    "playwright": "1.59.1",
    "sharp": "^0.34.2",
    "size-limit": "^12.1.0",
    "tw-animate-css": "^1.2.8",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.1.4"
  }
}
