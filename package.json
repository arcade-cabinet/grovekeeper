{
  "name": "grove-keeper",
  "private": true,
  "version": "1.0.0-alpha.1",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "install-and-dev": "pnpm install && pnpm dev",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview --port 8080",
    "tsc": "tsc",
    "tscgo": "tsgo",
    "tsc-watch": "tsc --watch",
    "dev:prod": "concurrently \"npm run build:watch\" \"npm run preview\"",
    "test": "vitest --project node",
    "test:run": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "test:all": "vitest run",
    "test:coverage": "vitest run --project node --coverage",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui"
  },
  "dependencies": {
    "@babylonjs/core": "^8.50.0",
    "@babylonjs/loaders": "^8.50.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@tailwindcss/vite": "^4.1.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "koota": "^0.6.6",
    "solid-js": "^1.9.12",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "tone": "^15.1.22",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3",
    "@capacitor/cli": "^8.0.2",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@types/sql.js": "^1.4.9",
    "@types/yuka": "^0.7.4",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.8",
    "happy-dom": "^20.5.0",
    "playwright": "^1.59.1",
    "tw-animate-css": "^1.2.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.1.4"
  }
}
