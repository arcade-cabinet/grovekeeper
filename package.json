{
  "name": "grove-keeper",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "install-and-dev": "pnpm install && pnpm dev",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview --port 8080",
    "tsc": "tsc",
    "tscgo": "tsgo",
    "tsc-watch": "tsc --watch",
    "dev:prod": "concurrently \"npm run build:watch\" \"npm run preview\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "pnpm build && playwright test --ui"
  },
  "dependencies": {
    "@babylonjs/core": "^8.50.0",
    "@babylonjs/loaders": "^8.50.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-progress": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.6",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slider": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.9",
    "@radix-ui/react-toggle": "^1.1.6",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@remixicon/react": "4.6.0",
    "@tailwindcss/vite": "^4.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "koota": "^0.6.6",
    "lucide-react": "^0.503.0",
    "miniplex": "^2.0.0",
    "miniplex-react": "^2.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solid-js": "^1.9.12",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3",
    "@capacitor/cli": "^8.0.2",
    "@playwright/test": "^1.58.2",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.8",
    "happy-dom": "^20.5.0",
    "tw-animate-css": "^1.2.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-singlefile": "^2.3.0",
